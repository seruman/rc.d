#!/usr/bin/env bun

import { SessionManager, type SessionInfo } from "@mariozechner/pi-coding-agent";
import { basename } from "path";

const isTTY = !!process.stdout.isTTY;

const c = {
  reset: isTTY ? "\x1b[0m" : "",
  bold: isTTY ? "\x1b[1m" : "",
  dim: isTTY ? "\x1b[2m" : "",
  cyan: isTTY ? "\x1b[36m" : "",
  yellow: isTTY ? "\x1b[33m" : "",
  green: isTTY ? "\x1b[32m" : "",
  magenta: isTTY ? "\x1b[35m" : "",
  blue: isTTY ? "\x1b[34m" : "",
};

function homeDir(): string {
  return process.env.HOME || "";
}

function shortenHome(s: string): string {
  const home = homeDir();
  if (!home) return s;
  if (s === home) return "~";
  if (s.startsWith(home + "/")) return "~" + s.slice(home.length);
  return s;
}

function trunc(s: string, n: number): string {
  if (s.length <= n) return s;
  return `${s.slice(0, n - 1)}…`;
}

function padRight(s: string, width: number): string {
  if (s.length >= width) return s;
  return s + " ".repeat(width - s.length);
}

function displayName(s: SessionInfo): string {
  const raw = s.name || s.firstMessage || "";
  return raw.replace(/[\n\r\t]+/g, " ").trim();
}

function termWidth(): number {
  return process.stdout.columns || 120;
}

function printTree(sessions: SessionInfo[]): void {
  const byCwd = new Map<string, SessionInfo[]>();
  for (const s of sessions) {
    const cwd = shortenHome(s.cwd) || "(unknown)";
    let list = byCwd.get(cwd);
    if (!list) {
      list = [];
      byCwd.set(cwd, list);
    }
    list.push(s);
  }

  const cwds = Array.from(byCwd.keys()).sort();
  for (const cwd of cwds) {
    const list = byCwd.get(cwd)!;
    list.sort((a, b) => +b.modified - +a.modified);
    console.log(`${c.bold}${c.blue}${cwd}${c.reset}`);
    list.forEach((s, idx) => {
      const connector = idx === list.length - 1 ? "└── " : "├── ";
      const name = displayName(s);
      const leafName = basename(s.path);
      const msgTag = `${c.yellow}x${s.messageCount}${c.reset}`;
      const prefixLen = 1 + 4; // space + connector
      const fixedLen = prefixLen + leafName.length + 1 + `x${s.messageCount}`.length;
      const nameBudget = Math.max(40, termWidth() - fixedLen - 1);
      const nameStr = name ? ` ${trunc(name, nameBudget)}` : "";
      console.log(` ${c.dim}${connector}${leafName}${c.reset} ${msgTag}${nameStr}`);
    });
    console.log();
  }
}

async function main() {
  const args = new Set(process.argv.slice(2));
  const treeMode = args.has("--tree") || args.has("-t");

  const sessions = await SessionManager.listAll();

  if (sessions.length === 0) {
    console.log("No sessions found");
    return;
  }

  sessions.sort((a, b) => +b.modified - +a.modified);

  if (treeMode) {
    printTree(sessions);
    return;
  }

  console.log(`${sessions.length} session(s)\n`);
  console.log(
    [padRight("modified", 20), padRight("messages", 8), padRight("id", 36), padRight("name", 40), "cwd"].join(
      "  ",
    ),
  );

  for (const s of sessions) {
    const modified = s.modified.toISOString().replace("T", " ").slice(0, 19);
    console.log(
      [
        padRight(modified, 20),
        padRight(String(s.messageCount), 8),
        padRight(s.id, 36),
        padRight(trunc(displayName(s) || "-", 40), 40),
        shortenHome(s.cwd) || "-",
      ].join("  "),
    );
  }
}

await main();
